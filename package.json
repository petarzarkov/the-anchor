{
  "name": "tauri-vite-template",
  "version": "0.0.1",
  "private": true,
  "description": "Tauri Vite Template - A starter template for building Tauri applications with Vite and React.",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "check": "biome ci .",
    "lint": "biome check --write --unsafe .",
    "format": "biome format --write .",
    "tauri:dev": "tauri dev --config service/tauri.conf.json",
    "tauri:build": "tauri build --config service/tauri.conf.json"
  },
  "dependencies": {
    "@chakra-ui/react": "3.34.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-shell": "2.3.5",
    "framer-motion": "12.36.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/bun": "1.3.10",
    "@types/node": "25.5.0",
    "@tauri-apps/cli": "2.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "husky": "9.1.7",
    "typescript": "5.9.3",
    "vite": "8.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bun run lint",
      "bun run format"
    ]
  }
}
